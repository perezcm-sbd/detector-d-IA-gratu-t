<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Detector d'IA</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f0; color: #1a1a1a; min-height: 100vh; padding: 2rem 1rem; }
  .container { max-width: 720px; margin: 0 auto; }
  h1 { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
  .subtitle { font-size: 14px; color: #666; margin-bottom: 1.5rem; }
 
  .api-card { background: #fff; border: 1px solid #e0e0d8; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
  .api-card label { font-size: 13px; font-weight: 500; color: #444; display: block; margin-bottom: 6px; }
  .api-row { display: flex; gap: 8px; }
  .api-row input { flex: 1; border: 1px solid #ddd; border-radius: 8px; padding: 9px 12px; font-size: 14px; background: #fafaf8; color: #1a1a1a; }
  .api-row input:focus { outline: none; border-color: #999; }
  .api-hint { font-size: 12px; color: #888; margin-top: 8px; line-height: 1.6; }
  .api-hint a { color: #1a5276; }
  .steps { margin-top: 8px; padding-left: 0; list-style: none; }
  .steps li { font-size: 12px; color: #888; padding: 2px 0; }
  .steps li::before { content: "→ "; color: #aaa; }
 
  .card { background: #fff; border: 1px solid #e0e0d8; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
 
  .tab-row { display: flex; border: 1px solid #e0e0d8; border-radius: 8px; overflow: hidden; margin-bottom: 12px; }
  .tab { flex: 1; padding: 8px; font-size: 13px; font-weight: 500; border: none; background: transparent; cursor: pointer; color: #888; transition: background 0.15s; }
  .tab.active { background: #f0f0ea; color: #1a1a1a; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
 
  .drop-zone { border: 1.5px dashed #ccc; border-radius: 8px; padding: 28px; text-align: center; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
  .drop-zone:hover, .drop-zone.dragover { background: #f5f5f0; border-color: #999; }
  .drop-zone .icon { font-size: 32px; margin-bottom: 8px; }
  .drop-zone p { font-size: 14px; color: #555; }
  .drop-zone span { font-size: 12px; color: #999; display: block; margin-top: 4px; }
 
  .file-info { display: none; align-items: center; gap: 10px; padding: 10px 14px; background: #f5f5f0; border-radius: 8px; margin-bottom: 12px; font-size: 14px; }
  .file-info.visible { display: flex; }
  .file-name { font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .file-size { color: #888; font-size: 12px; }
  .btn-remove { background: none; border: none; cursor: pointer; color: #999; font-size: 18px; line-height: 1; padding: 0 4px; }
  .btn-remove:hover { color: #333; }
 
  textarea { width: 100%; min-height: 150px; border: 1px solid #e0e0d8; border-radius: 8px; padding: 12px; font-family: inherit; font-size: 14px; color: #1a1a1a; background: #fafaf8; resize: vertical; line-height: 1.6; }
  textarea:focus { outline: none; border-color: #999; }
 
  .btn-row { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
  button { border: 1px solid #ddd; background: transparent; border-radius: 8px; padding: 8px 16px; font-size: 14px; font-weight: 500; cursor: pointer; color: #1a1a1a; transition: background 0.15s; }
  button:hover { background: #f0f0ea; }
  button:active { transform: scale(0.98); }
  button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  .btn-primary { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .btn-primary:hover { background: #333; }
 
  /* Progress steps */
  .progress-wrap { margin-bottom: 1rem; }
  .progress-label { font-size: 13px; color: #666; margin-bottom: 8px; }
  .progress-steps { display: flex; gap: 6px; }
  .step-pill { flex: 1; height: 6px; border-radius: 99px; background: #e0e0d8; transition: background 0.4s; }
  .step-pill.done { background: #1a7a4a; }
  .step-pill.active { background: #d08000; }
  .step-text { font-size: 12px; color: #999; margin-top: 6px; min-height: 18px; }
 
  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; margin-bottom: 1rem; }
  .metric { background: #f5f5f0; border-radius: 8px; padding: 12px; text-align: center; }
  .metric-label { font-size: 12px; color: #888; margin-bottom: 6px; }
  .metric-value { font-size: 22px; font-weight: 600; }
 
  .meter-bar { height: 8px; background: #ebebeb; border-radius: 99px; overflow: hidden; margin: 8px 0 4px; }
  .meter-fill { height: 100%; border-radius: 99px; transition: width 0.6s ease; }
 
  .verdict { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-radius: 8px; margin-bottom: 1rem; font-size: 14px; font-weight: 500; }
 
  .section-title { font-size: 12px; font-weight: 600; color: #888; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em; }
 
  .rounds-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 1rem; }
  .round-card { background: #f5f5f0; border-radius: 8px; padding: 10px 12px; }
  .round-title { font-size: 11px; color: #999; margin-bottom: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
  .round-pct { font-size: 18px; font-weight: 600; }
  .round-desc { font-size: 11px; color: #888; margin-top: 2px; }
 
  .indicators { margin: 12px 0; }
  .indicator-tag { display: inline-flex; font-size: 12px; padding: 3px 10px; border-radius: 99px; margin: 3px; }
 
  .analysis-text { font-size: 14px; color: #555; line-height: 1.7; }
 
  .humanized-box { background: #fafaf8; border: 1px solid #e0e0d8; border-radius: 8px; padding: 14px; font-size: 14px; line-height: 1.7; white-space: pre-wrap; }
 
  .error-box { background: #fff0f0; border: 1px solid #fcc; border-radius: 8px; padding: 12px 14px; font-size: 14px; color: #a00; margin-bottom: 10px; }
  .warning-box { background: #fffbe6; border: 1px solid #ffe58f; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #7a5800; margin-bottom: 10px; }
 
  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: -2px; margin-right: 6px; }
  @keyframes spin { to { transform: rotate(360deg); } }
 
  .results-wrap { display: none; }
  .results-wrap.visible { display: block; }
  .copy-btn { font-size: 12px; padding: 5px 12px; }
  .badge-free { display: inline-block; background: #eafaf1; color: #1a7a4a; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 99px; margin-left: 8px; vertical-align: middle; }
  .groq-logo { display: inline-block; background: #f2a900; color: #000; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 99px; margin-left: 6px; vertical-align: middle; }
</style>
</head>
<body>
<div class="container">
  <h1>🔍 Detector d'IA <span class="badge-free">100% GRATUÏT</span> <span class="groq-logo">Groq</span></h1>
  <p class="subtitle">Detecta l'ús d'IA en un text amb 3 anàlisis paral·leles per a un resultat més fiable.</p>
 
  <div class="api-card">
    <label for="apiKey">Clau API de Groq (gratuïta, sense targeta)</label>
    <div class="api-row">
      <input type="password" id="apiKey" placeholder="gsk_..." autocomplete="off">
      <button onclick="toggleKey()">Mostrar</button>
    </div>
    <ul class="steps">
      <li>Ves a <a href="https://console.groq.com" target="_blank">console.groq.com</a> i registra't amb Google o GitHub</li>
      <li>Al menú esquerre clica "API Keys" → "Create API Key"</li>
      <li>Copia la clau (comença per <strong>gsk_</strong>) i enganxa-la aquí</li>
    </ul>
  </div>
 
  <div class="card">
    <div class="tab-row">
      <button class="tab active" onclick="switchInput('text')">✏️ Text</button>
      <button class="tab" onclick="switchInput('file')">📄 Arxiu</button>
    </div>
 
    <div id="panel-text" class="tab-content active">
      <textarea id="inputText" placeholder="Enganxa aquí el teu text..."></textarea>
    </div>
 
    <div id="panel-file" class="tab-content">
      <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)">
        <div class="icon">📂</div>
        <p>Arrossega l'arxiu aquí o clica per seleccionar</p>
        <span>Compatible amb .txt, .md, .docx, .pdf (text), .html, .csv</span>
      </div>
      <input type="file" id="fileInput" accept=".txt,.md,.docx,.pdf,.html,.htm,.csv,.rtf" style="display:none" onchange="handleFile(this.files[0])">
      <div class="file-info" id="fileInfo">
        <span>📄</span>
        <span class="file-name" id="fileName"></span>
        <span class="file-size" id="fileSize"></span>
        <button class="btn-remove" onclick="removeFile()">✕</button>
      </div>
      <textarea id="filePreview" placeholder="El contingut de l'arxiu apareixerà aquí per revisar-lo..."></textarea>
    </div>
 
    <div class="btn-row">
      <button class="btn-primary" id="analyzeBtn" onclick="analyze()">🔍 Analitzar (3 rondes)</button>
      <button onclick="clearAll()">🗑 Esborrar</button>
    </div>
  </div>
 
  <div class="results-wrap" id="resultsWrap">
    <div class="card">
      <div id="errorBox" class="error-box" style="display:none"></div>
 
      <!-- Progress -->
      <div class="progress-wrap" id="progressWrap" style="display:none">
        <div class="progress-label">Analitzant amb 3 enfocaments diferents...</div>
        <div class="progress-steps">
          <div class="step-pill" id="pill1"></div>
          <div class="step-pill" id="pill2"></div>
          <div class="step-pill" id="pill3"></div>
        </div>
        <div class="step-text" id="stepText"></div>
      </div>
 
      <div id="mainResults" style="display:none">
        <div class="warning-box">⚠️ Resultat orientatiu — cap detector d'IA és infalible. Usa'l com a referència, no com a veredicte definitiu.</div>
 
        <div class="metrics-grid">
          <div class="metric">
            <div class="metric-label">🤖 IA detectada (mitjana)</div>
            <div class="metric-value" id="pctIA" style="color:#c0392b">—</div>
          </div>
          <div class="metric">
            <div class="metric-label">🧑 Humà</div>
            <div class="metric-value" id="pctHuman" style="color:#1a7a4a">—</div>
          </div>
          <div class="metric">
            <div class="metric-label">📝 Paraules</div>
            <div class="metric-value" id="wordCount">—</div>
          </div>
          <div class="metric">
            <div class="metric-label">⚠️ Risc</div>
            <div class="metric-value" id="riskLevel" style="font-size:16px">—</div>
          </div>
        </div>
 
        <div class="meter-bar">
          <div class="meter-fill" id="meterFill" style="width:0%"></div>
        </div>
 
        <div class="verdict" id="verdictBox"></div>
 
        <!-- 3 rounds detail -->
        <div class="section-title" style="margin-top:14px">Detall de les 3 rondes</div>
        <div class="rounds-grid">
          <div class="round-card">
            <div class="round-title">Ronda 1 — Estil</div>
            <div class="round-pct" id="r1pct">—</div>
            <div class="round-desc" id="r1desc"></div>
          </div>
          <div class="round-card">
            <div class="round-title">Ronda 2 — Estructura</div>
            <div class="round-pct" id="r2pct">—</div>
            <div class="round-desc" id="r2desc"></div>
          </div>
          <div class="round-card">
            <div class="round-title">Ronda 3 — Patrons IA</div>
            <div class="round-pct" id="r3pct">—</div>
            <div class="round-desc" id="r3desc"></div>
          </div>
        </div>
 
        <div class="section-title">Indicadors detectats</div>
        <div class="indicators" id="indicators"></div>
 
        <div class="section-title" style="margin-top:14px">Anàlisi detallada</div>
        <div class="analysis-text" id="analysisText"></div>
 
        <div id="humanizeSection" style="display:none;margin-top:1rem">
          <div class="btn-row">
            <button class="btn-primary" id="humanizeBtn" onclick="humanize()">✨ Humanitzar text</button>
          </div>
        </div>
      </div>
    </div>
 
    <div class="card" id="humanizeCard" style="display:none">
      <div class="section-title">Text humanitzat</div>
      <div class="tab-row">
        <button class="tab active" onclick="switchResultTab('humanized')">Humanitzat</button>
        <button class="tab" onclick="switchResultTab('original')">Original</button>
      </div>
      <div id="rtab-humanized" class="tab-content active">
        <div class="humanized-box" id="humanizedText"></div>
        <div class="btn-row" style="margin-top:10px">
          <button class="copy-btn" onclick="copyText()">📋 Copiar</button>
          <button class="copy-btn" onclick="reanalyzeHumanized()">🔄 Reanalitzar</button>
        </div>
      </div>
      <div id="rtab-original" class="tab-content">
        <div class="humanized-box" id="originalCompare"></div>
      </div>
    </div>
  </div>
</div>
 
<script>
let lastHumanized = '';
let currentMode = 'text';
 
function toggleKey() {
  const inp = document.getElementById('apiKey');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}
 
function switchInput(mode) {
  currentMode = mode;
  const tabs = document.querySelector('.card .tab-row').querySelectorAll('.tab');
  tabs[0].classList.toggle('active', mode === 'text');
  tabs[1].classList.toggle('active', mode === 'file');
  document.getElementById('panel-text').classList.toggle('active', mode === 'text');
  document.getElementById('panel-file').classList.toggle('active', mode === 'file');
}
 
function getActiveText() {
  return currentMode === 'text'
    ? document.getElementById('inputText').value.trim()
    : document.getElementById('filePreview').value.trim();
}
 
function onDragOver(e) { e.preventDefault(); document.getElementById('dropZone').classList.add('dragover'); }
function onDragLeave() { document.getElementById('dropZone').classList.remove('dragover'); }
function onDrop(e) { e.preventDefault(); onDragLeave(); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); }
 
async function handleFile(file) {
  if (!file) return;
  if (file.size > 5 * 1024 * 1024) { alert('Arxiu massa gran. Màxim 5 MB.'); return; }
  document.getElementById('fileName').textContent = file.name;
  document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
  document.getElementById('fileInfo').classList.add('visible');
  document.getElementById('dropZone').style.display = 'none';
  const ext = file.name.split('.').pop().toLowerCase();
  try {
    let text = '';
    if (ext === 'docx') {
      const buf = await file.arrayBuffer();
      const res = await mammoth.extractRawText({ arrayBuffer: buf });
      text = res.value;
    } else if (ext === 'pdf') {
      text = await readPdfText(file);
    } else {
      text = await file.text();
      if (ext === 'html' || ext === 'htm') { const d = document.createElement('div'); d.innerHTML = text; text = d.innerText; }
    }
    document.getElementById('filePreview').value = text;
  } catch (err) { alert('No s\'ha pogut llegir l\'arxiu: ' + err.message); }
}
 
function readPdfText(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = e => {
      const bytes = new Uint8Array(e.target.result);
      let raw = '';
      for (let i = 0; i < bytes.length; i++) raw += String.fromCharCode(bytes[i]);
      const blocks = raw.match(/BT[\s\S]*?ET/g) || [];
      let text = blocks.map(b => (b.match(/\(([^)]*)\)\s*Tj/g) || []).map(t => t.replace(/\(([^)]*)\)\s*Tj/, '$1')).join(' ')).join('\n').trim();
      if (text.length < 20) reject(new Error('PDF escanejat o protegit. Copia el text manualment.'));
      else resolve(text);
    };
    reader.onerror = () => reject(new Error('Error llegint el PDF.'));
    reader.readAsArrayBuffer(file);
  });
}
 
function removeFile() {
  document.getElementById('fileInfo').classList.remove('visible');
  document.getElementById('dropZone').style.display = '';
  document.getElementById('filePreview').value = '';
  document.getElementById('fileInput').value = '';
}
 
async function callGroq(systemPrompt, userPrompt, temp = 0.3) {
  const key = document.getElementById('apiKey').value.trim();
  if (!key) throw new Error('Cal introduir la clau API de Groq primer.');
  const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key },
    body: JSON.stringify({
      model: 'llama-3.3-70b-versatile',
      temperature: temp,
      max_tokens: 600,
      messages: [{ role: 'system', content: systemPrompt }, { role: 'user', content: userPrompt }]
    })
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message);
  return data.choices[0].message.content;
}
 
function parseJSON(raw) {
  try { return JSON.parse(raw.replace(/```json|```/g, '').trim()); }
  catch { return JSON.parse((raw.match(/\{[\s\S]+\}/) || ['{}'])[0]); }
}
 
function setStep(step) {
  const labels = ['', 'Ronda 1: analitzant estil i vocabulari...', 'Ronda 2: analitzant estructura i coherència...', 'Ronda 3: buscant patrons típics d\'IA...'];
  for (let i = 1; i <= 3; i++) {
    const pill = document.getElementById('pill' + i);
    pill.className = 'step-pill' + (i < step ? ' done' : i === step ? ' active' : '');
  }
  document.getElementById('stepText').textContent = labels[step] || '';
}
 
function setBtn(id, loading) {
  const b = document.getElementById(id);
  if (loading) { b._orig = b.innerHTML; b.disabled = true; b.innerHTML = '<span class="spinner"></span>Analitzant...'; }
  else { b.disabled = false; b.innerHTML = b._orig || ''; }
}
 
function showError(msg) {
  document.getElementById('errorBox').textContent = 'Error: ' + msg;
  document.getElementById('errorBox').style.display = 'block';
}
 
const ROUNDS = [
  {
    id: 1,
    focus: 'estil i vocabulari',
    system: `Ets un expert en detecció de text generat per IA. Analitza el text centrant-te en: naturalitat del vocabulari, varietat lèxica, presència de col·loquialismes, expressions personals, i si el to sembla humà o sintètic. Retorna ÚNICAMENT JSON pur sense markdown:
{"pct_ia":<enter 0-100>,"resum":"<1 frase breu en català>","indicadors":["ind1","ind2"]}`
  },
  {
    id: 2,
    focus: 'estructura i coherència',
    system: `Ets un expert en detecció de text generat per IA. Analitza el text centrant-te en: estructura de les frases, coherència del discurs, repeticions, transicions, longitud de paràgrafs, i si l'organització del text sembla generada per IA. Retorna ÚNICAMENT JSON pur sense markdown:
{"pct_ia":<enter 0-100>,"resum":"<1 frase breu en català>","indicadors":["ind1","ind2"]}`
  },
  {
    id: 3,
    focus: 'patrons típics d\'IA',
    system: `Ets un expert en detecció de text generat per IA. Analitza el text centrant-te en: frases introductòries típiques de LLMs ("En conclusió...", "És important destacar..."), excés de formalitat, manca d'errors naturals, perfecció gramatical excessiva, i patrons lingüístics propis de models de llenguatge. Sigues especialment crític i desconfiat. Retorna ÚNICAMENT JSON pur sense markdown:
{"pct_ia":<enter 0-100>,"resum":"<1 frase breu en català>","indicadors":["ind1","ind2"]}`
  }
];
 
async function analyze() {
  const text = getActiveText();
  if (!text) { alert('Afegeix text per analitzar.'); return; }
 
  setBtn('analyzeBtn', true);
  document.getElementById('resultsWrap').classList.add('visible');
  document.getElementById('errorBox').style.display = 'none';
  document.getElementById('humanizeCard').style.display = 'none';
  document.getElementById('mainResults').style.display = 'none';
  document.getElementById('progressWrap').style.display = 'block';
 
  const truncated = text.length > 3500 ? text.slice(0, 3500) : text;
  const results = [];
 
  try {
    for (let i = 0; i < ROUNDS.length; i++) {
      const round = ROUNDS[i];
      setStep(i + 1);
      const raw = await callGroq(round.system, 'Analitza aquest text:\n\n' + truncated, 0.2 + i * 0.15);
      const json = parseJSON(raw);
      results.push({ pct: Math.round(json.pct_ia || 0), resum: json.resum || '', indicadors: json.indicadors || [] });
      document.getElementById('r' + round.id + 'pct').textContent = results[i].pct + '%';
      document.getElementById('r' + round.id + 'pct').style.color = results[i].pct < 30 ? '#1a7a4a' : results[i].pct < 60 ? '#d08000' : '#c0392b';
      document.getElementById('r' + round.id + 'desc').textContent = results[i].resum;
    }
 
    // Mitjana ponderada: ronda 3 (patrons IA) té més pes
    const pct = Math.round((results[0].pct * 1 + results[1].pct * 1 + results[2].pct * 1.5) / 3.5);
    const allIndicadors = [...new Set([...results[0].indicadors, ...results[1].indicadors, ...results[2].indicadors])];
 
    // Anàlisi final combinada
    setStep(4);
    document.getElementById('stepText').textContent = 'Generant anàlisi final...';
    const finalSystem = `Ets un expert en detecció de text generat per IA. Basant-te en les tres anàlisis prèvies, escriu una anàlisi final de 3-4 frases en català que expliqui el veredicte. Retorna ÚNICAMENT JSON pur:
{"analisi":"<3-4 frases en català>"}`;
    const finalPrompt = `Les tres rondes han donat: ${results[0].pct}% IA (estil), ${results[1].pct}% IA (estructura), ${results[2].pct}% IA (patrons). Mitjana: ${pct}%. Indicadors: ${allIndicadors.join(', ')}. Text analitzat:\n\n${truncated.slice(0,1000)}`;
    const finalRaw = await callGroq(finalSystem, finalPrompt, 0.3);
    const finalJson = parseJSON(finalRaw);
 
    // Render resultats
    document.getElementById('progressWrap').style.display = 'none';
    document.getElementById('mainResults').style.display = 'block';
 
    document.getElementById('pctIA').textContent = pct + '%';
    document.getElementById('pctHuman').textContent = (100 - pct) + '%';
    document.getElementById('wordCount').textContent = text.split(/\s+/).filter(Boolean).length;
 
    const risc = pct < 20 ? 'Baix' : pct < 50 ? 'Mig' : pct < 75 ? 'Alt' : 'Molt alt';
    document.getElementById('riskLevel').textContent = risc;
 
    const fill = document.getElementById('meterFill');
    fill.style.width = pct + '%';
    fill.style.background = pct < 30 ? '#1a7a4a' : pct < 60 ? '#d08000' : '#c0392b';
 
    const vbox = document.getElementById('verdictBox');
    if (pct < 20) { vbox.style.cssText = 'display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:8px;margin-bottom:1rem;font-size:14px;font-weight:500;background:#eafaf1;color:#1a7a4a'; vbox.textContent = '✅ Text majoritàriament humà'; }
    else if (pct < 50) { vbox.style.cssText = 'display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:8px;margin-bottom:1rem;font-size:14px;font-weight:500;background:#fef9e7;color:#a07000'; vbox.textContent = '⚠️ Text parcialment generat per IA'; }
    else { vbox.style.cssText = 'display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:8px;margin-bottom:1rem;font-size:14px;font-weight:500;background:#fdedec;color:#a00'; vbox.textContent = '🤖 Text altament generat per IA'; }
 
    const colors = ['#eafaf1','#fef9e7','#fdedec','#eaf2fb','#f5eef8'];
    const tcolors = ['#1a7a4a','#a07000','#a00','#1a5276','#6c3483'];
    document.getElementById('indicators').innerHTML = allIndicadors.map((ind, i) =>
      `<span class="indicator-tag" style="background:${colors[i%5]};color:${tcolors[i%5]}">${ind}</span>`
    ).join('');
 
    document.getElementById('analysisText').textContent = finalJson.analisi || '';
    document.getElementById('humanizeSection').style.display = pct >= 10 ? 'block' : 'none';
 
  } catch (err) {
    document.getElementById('progressWrap').style.display = 'none';
    document.getElementById('mainResults').style.display = 'block';
    showError(err.message);
  }
 
  setBtn('analyzeBtn', false);
}
 
async function humanize() {
  const text = getActiveText();
  if (!text) return;
  const btn = document.getElementById('humanizeBtn');
  btn._orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Humanitzant...';
 
  try {
    const truncated = text.length > 4000 ? text.slice(0, 4000) : text;
    const system = `Ets un especialista en reescriure text perquè soni completament humà i natural. Reescriu el text mantenint el CONTINGUT i SIGNIFICAT exactament igual, però: varia la longitud de les frases, afegeix connectors naturals, inclou petites imperfeccions sintàctiques naturals, elimina patrons repetitius típics d'IA, usa sinònims menys formals quan escaigui, mantén la llengua original. Retorna ÚNICAMENT el text reescrit, sense cap explicació.`;
    lastHumanized = await callGroq(system, truncated, 0.7);
    document.getElementById('humanizedText').textContent = lastHumanized;
    document.getElementById('originalCompare').textContent = text;
    document.getElementById('humanizeCard').style.display = 'block';
    document.getElementById('humanizeCard').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  } catch (err) { showError(err.message); }
 
  btn.disabled = false;
  btn.innerHTML = btn._orig;
}
 
function switchResultTab(tab) {
  document.querySelectorAll('#humanizeCard .tab').forEach((t, i) =>
    t.classList.toggle('active', (i===0&&tab==='humanized')||(i===1&&tab==='original')));
  document.getElementById('rtab-humanized').classList.toggle('active', tab === 'humanized');
  document.getElementById('rtab-original').classList.toggle('active', tab === 'original');
}
 
function copyText() {
  navigator.clipboard.writeText(lastHumanized).then(() => {
    const b = event.target.closest('button');
    const orig = b.textContent;
    b.textContent = '✅ Copiat!';
    setTimeout(() => { b.textContent = orig; }, 1500);
  });
}
 
function reanalyzeHumanized() {
  switchInput('text');
  document.getElementById('inputText').value = lastHumanized;
  document.getElementById('humanizeCard').style.display = 'none';
  analyze();
}
 
function clearAll() {
  document.getElementById('inputText').value = '';
  document.getElementById('filePreview').value = '';
  removeFile();
  document.getElementById('resultsWrap').classList.remove('visible');
  document.getElementById('humanizeCard').style.display = 'none';
  document.getElementById('errorBox').style.display = 'none';
}
</script>
</body>
</html>
